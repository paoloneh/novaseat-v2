# Copy this file to .env and adjust values as needed.
# Example: cp .env.example .env

POSTGRES_CONTAINER_NAME=novaseat-db
POSTGRES_PORT=5432
POSTGRES_DB=novaseat
POSTGRES_USER=novaseat
POSTGRES_PASSWORD=change_me
POSTGRES_VOLUME=pgdata

PGADMIN_CONTAINER_NAME=novaseat-pgadmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@novaseat.dev
PGADMIN_DEFAULT_PASSWORD=change_me

# Local n8n API (used by scripts/sync_n8n_workflows.py)
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=change_me

# Google Cloud — Colab Enterprise notebook execution (Workflow 1)
# These variables are read by the n8n Code node via $env.VARIABLE_NAME.
# Pass them to the n8n process/container so Workflow 1 can access them at runtime.
#
# If running n8n via Docker, add to the n8n service environment or env_file.
# If running n8n directly, export them in the shell before starting n8n.
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_CLOUD_NOTEBOOK_RUNTIME_TEMPLATE=your-runtime-template-id
COLAB_NOTEBOOK_GCS_URI=gs://your-bucket/colab/score_colab.ipynb
COLAB_OUTPUT_GCS_PREFIX=gs://your-bucket/colab/outputs

# n8n credential references — Google Service Account (used by sync script)
N8N_GOOGLE_CREDENTIAL_ID=
N8N_GOOGLE_CREDENTIAL_NAME=NovaSeat Google Service Account

# Notification recipients (used by Workflow 1 failure alerts)
DATA_TEAM_EMAIL=data-team@novaseat.dev
ALERT_FROM_EMAIL=noreply@novaseat.dev
