# Copy this file to .env and adjust values as needed.
# Example: cp .env.example .env

POSTGRES_CONTAINER_NAME=novaseat-db
POSTGRES_PORT=5432
POSTGRES_DB=novaseat
POSTGRES_USER=novaseat
POSTGRES_PASSWORD=change_me
POSTGRES_VOLUME=pgdata

PGADMIN_CONTAINER_NAME=novaseat-pgadmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@novaseat.dev
PGADMIN_DEFAULT_PASSWORD=change_me

# Local n8n API (used by scripts/sync_n8n_workflows.py)
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=change_me
